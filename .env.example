# Supabase（プロジェクト作成後に値を設定。.env.local にコピーして使う）
# publishable key は sb_publishable_... 形式。旧 anon キーは使わない。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 本番URL（OG image / sitemap の絶対URLに使用。未設定なら localhost:3000）
NEXT_PUBLIC_SITE_URL=

# 通報受信 Discord Webhook（任意。未設定でもDBには記録される）
DISCORD_WEBHOOK_URL=
